<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.recruit.jdbc.job.ICommentDao">


<!-- 댓글 작성 -->
<insert id="writeComment">
	insert into comment1 (cno, jno, mid, content, created_at) 
	values (com_seq.nextVal, #{jno}, #{mid}, #{content},sysdate)
</insert>

<!-- 댓글 수정 -->
<update id="updateComment">
	update comment1 set content = #{content}
</update>

<!-- 댓글 삭제 -->
<delete id="deleteComment">
	delete from comment1 where cno = #{cno}
</delete>




</mapper>